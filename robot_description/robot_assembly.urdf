<?xml version="1.0" ?>
<!--
  =====================================================================
  6-DOF Robot Arm + Gripper - Birleştirilmiş URDF
  Isaac Sim 5.1 için hazırlanmıştır.
  
  Kaynak dosyalar:
    - assembly/urdf/Assembly.xacro
    - gripper/urdf/gripper.urdf.xacro
  
  Kaldırılanlar (Isaac Sim'de gereksiz):
    - Assembly.gazebo (Gazebo eklentileri)
    - Assembly.ros2_control.xacro (ROS2 kontrol)
    - Assembly.trans (ROS2 transmission)
    
  Mesh klasörü: ./meshes/ (URDF ile aynı dizin)
  =====================================================================
-->
<robot name="Assembly">

  <!-- ===================== MATERYALLER ===================== -->
  <material name="silver">
    <color rgba="0.79 0.82 0.93 1.0"/>
  </material>
  <material name="gripper_grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="gripper_black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="mount_dark">
    <color rgba="0.18 0.18 0.18 1"/>
  </material>
  <material name="camera_black">
    <color rgba="0.08 0.08 0.08 1"/>
  </material>
  <material name="lens_gray">
    <color rgba="0.35 0.35 0.35 1"/>
  </material>
  <material name="lens_ring">
    <color rgba="0.2 0.2 0.2 1"/>
  </material>
  <material name="lens_glass">
    <color rgba="0.03 0.03 0.12 1"/>
  </material>

  <!-- ===================== DÜNYA LİNKİ ===================== -->
  <link name="world"/>

  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ===================== ANA ROBOT KOLUN LİNKLERİ ===================== -->

  <!-- BASE LINK - Robot tabanı -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0 0.158 0.053" rpy="0 0 0"/>
      <mass value="50.0"/>
      <inertia ixx="1.5" iyy="1.3" izz="1.6" ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0.15 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.4 0.1"/>
      </geometry>
    </collision>
  </link>

  <!-- LINK 1 - İlk döner eklem -->
  <link name="link1_1">
    <inertial>
      <origin xyz="0.146 -0.001 0.157" rpy="0 0 0"/>
      <mass value="15.0"/>
      <inertia ixx="0.3" iyy="0.5" izz="0.4" ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="-0.0 -0.191165 -0.257989" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/link1_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.13 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.35"/>
      </geometry>
    </collision>
  </link>

  <!-- LINK 2 - Uzun kol parçası -->
  <link name="link2_1">
    <inertial>
      <origin xyz="0.0 -0.097 0.314" rpy="0 0 0"/>
      <mass value="12.0"/>
      <inertia ixx="0.5" iyy="0.5" izz="0.06" ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="-0.26 -0.116165 -0.526989" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/link2_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 -0.05 0.35" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.7"/>
      </geometry>
    </collision>
  </link>

  <!-- LINK 3 - Orta kol parçası -->
  <link name="link3_1">
    <inertial>
      <origin xyz="0.096 0.114 0.064" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="0.18" iyy="0.36" izz="0.22" ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="-0.26 -0.086165 -1.206989" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/link3_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.15 0.1 0.1" rpy="0 0 0"/>
      <geometry>
        <box size="0.35 0.15 0.2"/>
      </geometry>
    </collision>
  </link>

  <!-- LINK 4 - Bilek parçası -->
  <link name="link4_1">
    <inertial>
      <origin xyz="0.088 0.009 0.081" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.008" iyy="0.013" izz="0.009" ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="-0.626374 -0.216165 -1.512515" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/link4_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.09 0 0.08" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.18"/>
      </geometry>
    </collision>
  </link>

  <!-- LINK 5 - Son bilek -->
  <link name="link5_1">
    <inertial>
      <origin xyz="0.042 0.059 0.032" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.01" iyy="0.006" izz="0.012" ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="-0.766285 -0.152165 -1.641065" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/link5_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.04 0.06 0.03" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.06"/>
      </geometry>
    </collision>
  </link>

  <!-- ===================== ANA KOL EKLEMLERİ ===================== -->

  <joint name="Revolute_20" type="revolute">
    <origin xyz="0.0 0.191165 0.257989" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link1_1"/>
    <axis xyz="0.0 0.0 1.0"/>
    <limit lower="-3.14159" upper="3.14159" effort="200.0" velocity="2.0"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <joint name="Revolute_21" type="revolute">
    <origin xyz="0.26 -0.075 0.269" rpy="0 0 0"/>
    <parent link="link1_1"/>
    <child link="link2_1"/>
    <axis xyz="0.0 -1.0 0.0"/>
    <limit lower="-1.5708" upper="1.5708" effort="200.0" velocity="2.0"/>
    <dynamics damping="10.0" friction="2.0"/>
  </joint>

  <joint name="Revolute_22" type="revolute">
    <origin xyz="0.0 -0.03 0.68" rpy="0 0 0"/>
    <parent link="link2_1"/>
    <child link="link3_1"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="-1.5708" upper="1.5708" effort="200.0" velocity="2.0"/>
    <dynamics damping="8.0" friction="1.5"/>
  </joint>

  <joint name="Revolute_23" type="revolute">
    <origin xyz="0.366374 0.13 0.305526" rpy="0 0 0"/>
    <parent link="link3_1"/>
    <child link="link4_1"/>
    <axis xyz="0.73637 0.0 0.67658"/>
    <limit lower="-3.14159" upper="3.14159" effort="100.0" velocity="2.0"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <joint name="Revolute_24" type="revolute">
    <origin xyz="0.139911 -0.064 0.12855" rpy="0 0 0"/>
    <parent link="link4_1"/>
    <child link="link5_1"/>
    <axis xyz="-0.0 -1.0 0.0"/>
    <limit lower="-3.14159" upper="3.14159" effort="100.0" velocity="2.0"/>
    <dynamics damping="3.0" friction="0.5"/>
  </joint>

  <!-- ===================== GRİPPER (TUTUCU) ===================== -->

  <!-- Gripper base bağlantı eklemi -->
  <joint name="gripper_base_joint" type="revolute">
    <parent link="link5_1"/>
    <child link="gripper_base_link"/>
    <origin xyz="0.15 0.05 0.13" rpy="0.900 0 1.5708"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1415" upper="3.1415" effort="100.0" velocity="1.0"/>
    <dynamics damping="20.0" friction="5.0"/>
  </joint>

  <!-- Gripper gövdesi (orijinal: box_inertia m=1.0 w=0.24 h=0.08 d=0.08) -->
  <link name="gripper_base_link">
    <visual>
      <geometry>
        <box size="0.24 0.08 0.08"/>
      </geometry>
      <material name="gripper_grey"/>
    </visual>
    <!-- Küçük collision: rigid body oluşturulması için gerekli.
         z=-0.05'te, parmak hareket alanının (z=0→0.16) dışında. -->
    <collision>
      <origin xyz="0 0 -0.05"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <!-- ixx=(1/12)*(0.08^2+0.08^2)=0.001067  iyy=izz=(1/12)*(0.24^2+0.08^2)=0.005333 -->
      <inertia ixx="0.001067" ixy="0.0" ixz="0.0"
               iyy="0.005333" iyz="0.0"
               izz="0.005333"/>
    </inertial>
  </link>

  <!-- Sağ parmak (Franka Panda tarzı: joint=0 kapalı, joint=0.05 açık) -->
  <link name="right_finger">
    <visual>
      <origin xyz="0.01 0 0.08"/>
      <geometry>
        <box size="0.02 0.06 0.16"/>
      </geometry>
      <material name="gripper_black"/>
    </visual>
    <collision>
      <origin xyz="0.01 0 0.08"/>
      <geometry>
        <box size="0.02 0.06 0.16"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.000487" ixy="0.0" ixz="0.0"
               iyy="0.0000667" iyz="0.0"
               izz="0.000433"/>
    </inertial>
  </link>

  <!-- Sol parmak -->
  <link name="left_finger">
    <visual>
      <origin xyz="-0.01 0 0.08"/>
      <geometry>
        <box size="0.02 0.06 0.16"/>
      </geometry>
      <material name="gripper_black"/>
    </visual>
    <collision>
      <origin xyz="-0.01 0 0.08"/>
      <geometry>
        <box size="0.02 0.06 0.16"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.000487" ixy="0.0" ixz="0.0"
               iyy="0.0000667" iyz="0.0"
               izz="0.000433"/>
    </inertial>
  </link>

  <!-- Sağ parmak: axis +X, 0=kapalı, +0.11=açık (sağa kayar) -->
  <joint name="right_finger_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="right_finger"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.11" effort="20" velocity="0.2"/>
    <dynamics damping="10.0" friction="0.5"/>
  </joint>

  <!-- Sol parmak: axis -X, 0=kapalı, 0.11=açık (sola kayar) -->
  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="left_finger"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0.0" upper="0.11" effort="20" velocity="0.2"/>
    <dynamics damping="10.0" friction="0.5"/>
  </joint>

  <!-- ===================== KAMERA SİSTEMİ ===================== -->

  <!-- Kamera montaj braketi -->
  <link name="camera_mount_link">
    <visual>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.038" length="0.01"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.014" length="0.074"/>
      </geometry>
      <material name="mount_dark"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.096" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.030" length="0.008"/>
      </geometry>
      <material name="mount_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.038" length="0.10"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.07"/>
      <inertia ixx="0.00004" ixy="0" ixz="0" iyy="0.00004" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="camera_mount_joint" type="fixed">
    <parent link="link5_1"/>
    <child link="camera_mount_link"/>
    <origin xyz="0.02 0.06 0.06" rpy="0 -0.82 0"/>
  </joint>

  <!-- Kamera gövdesi -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0.028" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.065 0.048"/>
      </geometry>
      <material name="camera_black"/>
    </visual>
    <visual>
      <origin xyz="0.055 0 0.028" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.03"/>
      </geometry>
      <material name="lens_gray"/>
    </visual>
    <visual>
      <origin xyz="0.076 0 0.028" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.002"/>
      </geometry>
      <material name="lens_glass"/>
    </visual>
    <collision>
      <origin xyz="0.025 0 0.028" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.07 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="camera_mount_link"/>
    <child link="camera_link"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
  </joint>

</robot>
